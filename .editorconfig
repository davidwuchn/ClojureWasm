# https://editorconfig.org — editor-side consistency (pairs with .gitattributes).
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.zig]
indent_style = space
indent_size = 4

[*.{clj,cljc,cljs,edn}]
indent_style = space
indent_size = 2

[*.{yml,yaml,json,md}]
indent_style = space
indent_size = 2

[*.sh]
indent_style = space
indent_size = 4
